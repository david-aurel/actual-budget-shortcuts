{
  "name": "actual-budget-shortcuts",
  "version": "1.0.0",
  "description": "A Node.js web server for managing Actual Budget transactions. Provides endpoints for importing CSV transactions, adding transactions, and retrieving account IDs by communicating with an Actual Budget app.",
  "source": "src/index.ts",
  "scripts": {
    "build": "rm -rf build && tsc --p tsconfig.build.json",
    "ts:check": "tsc --noEmit",
    "eslint:check": "eslint --max-warnings=0 src",
    "prettier:check": "prettier -c .",
    "prettier:write": "prettier --write ."
  },
  "author": "david-aurel",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "@actual-app/api": "^26.5.0",
    "@oakserver/oak": "^14.1.0",
    "csvtojson": "^2.0.14",
    "dotenv": "^17.4.2",
    "envalid": "^8.1.1",
    "zod": "^4.4.3"
  }
}
